# Movie Review Bot - Environment Variables
# Copy this file to .env and fill in your API keys

# DeepSeek API (FREE - get at https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# TMDB API (FREE - get at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# OMDB API (FREE - get at http://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=your_omdb_api_key_here

# YouTube API (FREE - get at https://console.cloud.google.com)
# Download client_secret.json and place in project root
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json

# Channel Settings
CHANNEL_LANGUAGE=vi          # vi or en
CHANNEL_NAME=PhimHay Review  # Your channel name
